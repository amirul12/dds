{
    "kind": "collectionType",
    "collectionName": "member_directories",
    "info": {
        "singularName": "member-directory",
        "pluralName": "member-directories",
        "displayName": "Member Directory",
        "description": "Directory of all members of the Samiti"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "membershipType": {
            "type": "enumeration",
            "enum": [
                "Life",
                "General"
            ]
        },
        "overallSerial": {
            "type": "string",
            "unique": true
        },
        "thanaSerial": {
            "type": "string"
        },
        "fatherName": {
            "type": "string"
        },
        "motherName": {
            "type": "string"
        },
        "dob": {
            "type": "date"
        },
        "village": {
            "type": "string"
        },
        "union": {
            "type": "enumeration",
            "enum": [
                "Debhata",
                "Kulya",
                "Parulia",
                "Sakhipur",
                "Nawapara"
            ],
            "required": true
        },
        "permanentAddress": {
            "type": "text"
        },
        "presentAddress": {
            "type": "text"
        },
        "email": {
            "type": "email"
        },
        "phone": {
            "type": "string"
        },
        "education": {
            "type": "string"
        },
        "bloodGroup": {
            "type": "string"
        },
        "nid": {
            "type": "string"
        },
        "presentJob": {
            "type": "string"
        },
        "presentWorkplace": {
            "type": "string"
        },
        "designation": {
            "type": "string"
        },
        "organizations": {
            "type": "text"
        },
        "photo": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ]
        },
        "isVerified": {
            "type": "boolean",
            "default": false
        },
        "correction_requests": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::correction-request.correction-request",
            "mappedBy": "member"
        }
    }
}