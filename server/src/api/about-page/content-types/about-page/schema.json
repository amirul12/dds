    },
    "content": {
      "type": "richtext"
    },
    "establishedYear": {
      "type": "string",
      "default": "২০২২"
    },
    "officeLocation": {
      "type": "string",
      "default": "ঢাকা"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
